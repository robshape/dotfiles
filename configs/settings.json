{
  "biome.requireConfiguration": true,
  "biome.suggestInstallingGlobally": false,
  "chat.agent.maxRequests": 100,
  "chat.customAgentInSubagent.enabled": true,
  "chat.mcp.gallery.enabled": true,
  "chat.tips.enabled": false,
  "chat.tools.terminal.autoApprove": {
    "/^bash\\s+(?:\\.\\/)?\\.specify\\/scripts\\/bash\\/[^\\/]+\\.sh(\\s+[^;&|$`]+)*$/": true,
    "/^go (build|doc|fmt|list|mod tidy|test|vet)$/": true,
    "/^gofmt$/": true,
    "/^make (format|lint|test)$/": true,
    "/^pnpm (eslint|info|markdownlint-cli2|playwright test|prettier|vitest run)(\\s+[^\\;&\\|\\$\\`]+)?$/": true,
    "/^pnpm exec (eslint|lhci|playwright test|prettier|tsc|vitest run)(\\s+[^\\;&\\|\\$\\`]+)?$/": true,
    "/^CI=1 pnpm (test:e2e.*)(\\s+[^\\;&\\|\\$\\`]+)?$/": true
  },
  "chat.useCustomAgentHooks": true,
  "chat.useCustomizationsInParentRepositories": true,
  "chat.useNestedAgentsMdFiles": true,
  "code-runner.enableAppInsights": false,
  "debug.internalConsoleOptions": "neverOpen",
  "debug.openDebug": "neverOpen",
  "debug.toolBarLocation": "docked",
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.autoClosingQuotes": "beforeWhitespace",
  "editor.autoIndent": "keep",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.editContext": false,
  "editor.formatOnSave": true,
  "editor.lineNumbers": "relative",
  "editor.linkedEditing": true,
  "editor.links": false,
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "editor.renderWhitespace": "boundary",
  "editor.scrollBeyondLastLine": false,
  "editor.snippetSuggestions": "none",
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.wrappingIndent": "indent",
  "errorLens.enabledDiagnosticLevels": [
    "error",
    "warning"
  ],
  "errorLens.onSave": true,
  "eslint.run": "onSave",
  "explorer.autoReveal": false,
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.hotExit": "off",
  "files.insertFinalNewline": true,
  "files.restoreUndoStack": false,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "find-it-faster.advanced.disableStartupChecks": true,
  "find-it-faster.findFiles.previewCommand": "cat {}",
  "find-it-faster.findWithinFiles.previewCommand": "cat {1} | awk '{if (NR>={2}) print}'",
  "find-it-faster.general.showMaximizedTerminal": true,
  "git.addAICoAuthor": "all",
  "git.confirmSync": false,
  "git.promptToSaveFilesBeforeCommit": "staged",
  "github.copilot.chat.anthropic.contextEditing.mode": "clear-both",
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.organizationInstructions.enabled": false,
  "github.copilot.chat.searchSubagent.enabled": true,
  "github.copilot.enable": {
    "*": true,
    "dotenv": false
  },
  "github.copilot.nextEditSuggestions.allowWhitespaceOnlyChanges": false,
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.nextEditSuggestions.extendedRange": true,
  "githubIssues.workingBaseBranch": "defaultBranch",
  "githubPullRequests.createOnPublishBranch": "never",
  "githubPullRequests.defaultCommentType": "single",
  "githubPullRequests.defaultCreateOption": "createDraft",
  "githubPullRequests.defaultMergeMethod": "squash",
  "githubPullRequests.deleteBranchAfterMerge": true,
  "githubPullRequests.pushBranch": "always",
  "githubPullRequests.showPullRequestNumberInTree": true,
  "githubPullRequests.terminalLinksHandler": "vscode",
  "go.toolsManagement.autoUpdate": true,
  "gutterpreview.showImagePreviewOnGutter": false,
  "gutterpreview.showUnderline": false,
  "inlineChat.affordance": "editor",
  "inlineChat.defaultModel": "Claude Haiku 4.5 (copilot)",
  "inlineChat.renderMode": "hover",
  "jest.runMode": "on-demand",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true
  },
  "markdownlint.run": "onSave",
  "npm-intellisense.showBuildInLibs": true,
  "prettier.requireConfig": true,
  "search.followSymlinks": false,
  "search.quickOpen.includeHistory": false,
  "stylelint.reportNeedlessDisables": true,
  "telemetry.feedback.enabled": false,
  "telemetry.telemetryLevel": "off",
  "vim.easymotion": true,
  "vim.easymotionMarkerForegroundColorTwoCharFirst": "#1f51ff",
  "vim.easymotionMarkerForegroundColorTwoCharSecond": "#1f51ff",
  "vim.normalModeKeyBindings": [
    {
      "after": ["<leader>", "<leader>", "<leader>", "b", "d", "w"],
      "before": ["<space>"]
    }
  ],
  "vim.useSystemClipboard": true,
  "workbench.browser.enableChatTools": true,
  "workbench.browser.openLocalhostLinks": true,
  "workbench.browser.showInTitleBar": true,
  "workbench.colorTheme": "Light Modern",
  "workbench.commandPalette.history": 0,
  "workbench.editor.restoreEditors": false,
  "workbench.editor.restoreViewState": false,
  "workbench.enableExperiments": false,
  "workbench.settings.alwaysShowAdvancedSettings": true,
  "workbench.settings.enableNaturalLanguageSearch": false,
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false
}
