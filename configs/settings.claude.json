{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "medium",
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "env": {
    "ANTHROPIC_BASE_URL": "https://openrouter.ai/api/",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "google/gemma-4-31b-it:free",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "deepseek/deepseek-v4-pro",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek/deepseek-v4-flash",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "google/gemma-4-31b-it:free",
    "MAX_THINKING_TOKENS": "10000"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "printf '\\a' > $(tmux display -p -t \"$TMUX_PANE\" '#{pane_tty}')",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "printf '\\a' > $(tmux display -p -t \"$TMUX_PANE\" '#{pane_tty}')",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Bash(rtk find *)",
      "Bash(rtk git branch *)",
      "Bash(rtk git diff *)",
      "Bash(rtk git log *)",
      "Bash(rtk git stash *)",
      "Bash(rtk git status *)",
      "Bash(rtk go build *)",
      "Bash(rtk go test *)",
      "Bash(rtk grep *)",
      "Bash(rtk ls *)",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id"
    ]
  },
  "statusLine": {
    "command": "~/.claude/statusline/statusline.sh",
    "type": "command"
  },
  "theme": "light"
}
